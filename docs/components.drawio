        </mxCell>
        <mxCell id="consumer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=top;spacingTop=5;" value="Kafka Consumer&#xa;(Spring Boot)&#xa;Port: 8083&#xa;&#xa;- Consumer Group&#xa;- Batch Accumulation&#xa;- Retry with Backoff&#xa;- 2 Replicas" vertex="1">
          <mxGeometry height="140" width="220" x="500" y="570" as="geometry" />
        </mxCell>
        <mxCell id="tsdb" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;verticalAlign=top;spacingTop=5;" value="TSDB Server&#xa;(Spring Boot)&#xa;Port: 8080&#xa;&#xa;- Columnar Storage Engine&#xa;- PromQL Parser (ANTLR4)&#xa;- Prometheus HTTP API&#xa;- Write API" vertex="1">
