        </mxCell>

        <!-- TSDB Server -->
        <mxCell id="tsdb" value="TSDB Server&#xa;(Spring Boot)&#xa;Port: 8080&#xa;&#xa;- Columnar Storage Engine&#xa;- PromQL Parser (ANTLR4)&#xa;- Prometheus HTTP API&#xa;- Write API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
