          <mxGeometry x="480" y="320" width="140" height="120" as="geometry"/>
        </mxCell>

        <!-- Kafka Consumer -->
        <mxCell id="consumer" value="Kafka Consumer&#xa;(Spring Boot)&#xa;Port: 8083&#xa;&#xa;- Consumer Group&#xa;- Batch Accumulation&#xa;- Retry with Backoff&#xa;- 2 Replicas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
