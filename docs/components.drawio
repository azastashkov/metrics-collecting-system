        </mxCell>
        <mxCell id="load-client" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=top;spacingTop=5;" value="Load Client&#xa;(Java 21 / Spring Boot)&#xa;Port: 8081&#xa;&#xa;- Mock HTTP Server&#xa;- Load Generator (Virtual Threads)&#xa;- Prometheus /metrics" vertex="1">
          <mxGeometry height="140" width="220" x="90" y="150" as="geometry" />
        </mxCell>
        <mxCell id="collector" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=top;spacingTop=5;" value="Metrics Collector&#xa;(Spring Boot)&#xa;Port: 8082&#xa;&#xa;- Scrapes /metrics endpoints&#xa;- Parses Prometheus format&#xa;- Publishes to Kafka" vertex="1">
          <mxGeometry height="140" width="220" x="500" y="150" as="geometry" />
        </mxCell>
        <mxCell id="kafka" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;" value="Apache Kafka&#xa;(KRaft Mode)&#xa;&#xa;Topic: metrics-raw&#xa;3 Partitions" vertex="1">
