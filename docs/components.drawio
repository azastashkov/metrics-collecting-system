        <!-- Load Client -->
        <mxCell id="load-client" value="Load Client&#xa;(Java 21 / Spring Boot)&#xa;Port: 8081&#xa;&#xa;- Mock HTTP Server&#xa;- Load Generator (Virtual Threads)&#xa;- Prometheus /metrics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
