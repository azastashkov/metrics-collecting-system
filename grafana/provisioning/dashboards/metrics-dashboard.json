      "targets": [
        {
          "expr": "http_request_duration_seconds{quantile=\"0.95\"}",
          "legendFormat": "p95 {{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Latency P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "tsdb" },
      "targets": [
        {
          "expr": "http_request_duration_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99 {{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
