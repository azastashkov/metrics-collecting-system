          }
        },
        "overrides": []
      }
    },
    {
      "title": "Status Code Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "tsdb" },
      "targets": [
        {
          "expr": "sum by (status)(rate(http_requests_total[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
